# Wyzwanie 3: Parametry wyszukiwania
# Kopiuj ten plik do .env i dostosuj wartości

# Ustawienia serwera
HOST=0.0.0.0
PORT=8000

# Ustawienia modeli (lokalne lub Cloud Run)
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=embeddinggemma
LLM_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0

# Dla Cloud Run (jeśli używasz)
# EMBEDDING_URL=https://embedding-gemma-xyz.a.run.app
# LLM_URL=https://bielik-xyz.a.run.app

# Ustawienia bazy danych
# Dla BigQuery
PROJECT_ID=your-project-id
BIGQUERY_DATASET=rag_dataset
BIGQUERY_TABLE=hotel_rules
REGION=europe-west1

# Dla SQLite + FAISS (jeśli używasz)
# SQLITE_DB_PATH=rag_database.db
# FAISS_INDEX_PATH=faiss_index.bin

# Parametry wyszukiwania
TOP_K=3
MAX_K=100  # Maksymalna wartość k

# Debug
DEBUG=True
