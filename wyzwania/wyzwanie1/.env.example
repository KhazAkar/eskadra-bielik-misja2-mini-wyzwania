# Wyzwanie 1: Lokalne uruchomienie z SQLite + FAISS
# Kopiuj ten plik do .env i dostosuj wartości

# Ustawienia serwera
HOST=0.0.0.0
PORT=8000

# Ustawienia Ollama (lokalne)
OLLAMA_HOST=http://localhost:11434

# Model embeddingowy
EMBEDDING_MODEL=embeddinggemma

# Model LLM
LLM_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0

# Ustawienia bazy danych SQLite
SQLITE_DB_PATH=rag_database.db

# Ustawienia indeksu FAISS
FAISS_INDEX_PATH=faiss_index.bin

# Liczba wyników wyszukiwania (k)
TOP_K=3

# Debug
DEBUG=True
