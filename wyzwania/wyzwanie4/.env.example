# Wyzwanie 4: Endpoint /ask_summary
# Kopiuj ten plik do .env i dostosuj wartości

# Ustawienia serwera
HOST=0.0.0.0
PORT=8000

# Ustawienia modeli
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=embeddinggemma
LLM_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0

# Ustawienia bazy danych
PROJECT_ID=your-project-id
BIGQUERY_DATASET=rag_dataset
BIGQUERY_TABLE=hotel_rules
REGION=europe-west1

# Parametry podsumowań
SUMMARY_MAX_LENGTH=200  # Maksymalna długość podsumowania w znakach
SUMMARY_K=3  # Domyślna liczba dokumentów do podsumowania

# Debug
DEBUG=True
