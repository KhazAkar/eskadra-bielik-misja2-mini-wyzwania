# Wyzwanie 5: Obsługa plików PDF
# Kopiuj ten plik do .env i dostosuj wartości

# Ustawienia serwera
HOST=0.0.0.0
PORT=8000

# Ustawienia modeli
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=embeddinggemma
LLM_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0

# Ustawienia bazy danych
PROJECT_ID=your-project-id
BIGQUERY_DATASET=rag_dataset
BIGQUERY_TABLE=hotel_rules
REGION=europe-west1

# Parametry chunkingu PDF
PDF_CHUNK_SIZE=500  # Rozmiar fragmentu w znakach
PDF_CHUNK_OVERLAP=50  # Nakładka między fragmentami w znakach
MAX_PDF_SIZE_MB=10  # Maksymalny rozmiar pliku PDF w MB

# Biblioteka do ekstrakcji PDF (PyPDF2 lub pdfplumber)
PDF_LIBRARY=pypdf2  # lub 'pdfplumber'

# Debug
DEBUG=True
